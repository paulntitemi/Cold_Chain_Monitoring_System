# AWS Region
AWS_REGION=eu-west-1

# Cognito Identity Pool (unauthenticated guest access for Phase 1)
# Set by ./scripts/setup-mobile-backend.sh — paste the printed value here.
COGNITO_IDENTITY_POOL_ID=eu-west-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Gateway base URL (fronts Lambda → DynamoDB readings)
# Set by ./scripts/setup-mobile-backend.sh — paste the printed value here.
API_GATEWAY_BASE_URL=https://xxxxxxxxxx.execute-api.eu-west-1.amazonaws.com/prod

# IoT Core (used by Phase 2 MQTT path)
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.eu-west-1.amazonaws.com
# Must match a device actually publishing to MQTT.
# e.g. ESP32_TEST_002 if you have used run-test.sh / simulate-device.py.
IOT_THING_NAME=ESP32_TEST_002
IOT_DEVICE_ID=ESP32_TEST_002
MQTT_TOPIC_PREFIX=coldtrack

# Feature flags
# When false (Phase 1), the app polls API Gateway every 5 seconds.
# When true (Phase 2), the app opens a SigV4-signed MQTT WebSocket to IoT Core.
USE_MQTT_REALTIME=false

# Google Maps API key (optional — the map screen falls back to a list view
# with a hint if this is left as your_key_here).
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Default device ID used when onboarding does not supply one
DEFAULT_DEVICE_ID=ESP32_TEST_002
