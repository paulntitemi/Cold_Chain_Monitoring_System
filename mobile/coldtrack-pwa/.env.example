# AWS
VITE_AWS_REGION=eu-west-1
VITE_COGNITO_IDENTITY_POOL_ID=eu-west-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_API_GATEWAY_BASE_URL=https://xxxxxxxxxx.execute-api.eu-west-2.amazonaws.com/prod

# Auth (Phase 2)
VITE_REQUIRE_AUTH=false
VITE_COGNITO_USER_POOL_ID=eu-west-2_xxxxxxxxx
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Maps — same key as the dashboard
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Push
VITE_WEB_PUSH_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feature flags
VITE_USE_MOCK_DATA=true
VITE_ENABLE_VOICE_ALERTS=true
VITE_ENABLE_WEB_PUSH=true

influx=your_influx_token_here
